{
    "name": "medic-action",
    "version": "1.0.0",
    "type": "module",
    "description": "GitHub Action with manual and automated capabilities to resolve trivial blockers in merging PRs",
    "main": "dist/fixer-main/index.js",
    "scripts": {
        "prebuild": "rm -rf dist",
        "build": "pnpm run build:checker && pnpm run build:comment-parser && pnpm run build:fixer-main && pnpm run build:fixer-cleanup && pnpm run build:conflict-generator && pnpm run build:workflow-retry-parser && pnpm run build:workflow-retry && pnpm run build:workflow-retry-auto && pnpm run build:export-prompt && pnpm run build:clean",
        "build:checker": "ncc build src/checker.ts -o dist/checker --transpile-only",
        "build:comment-parser": "ncc build src/comment-parser.ts -o dist/comment-parser --transpile-only",
        "build:fixer-main": "ncc build src/fixer-main.ts -o dist/fixer-main --transpile-only",
        "build:fixer-cleanup": "ncc build src/fixer-cleanup.ts -o dist/fixer-cleanup --transpile-only",
        "build:conflict-generator": "ncc build src/conflict-generator.ts -o dist/conflict-generator --transpile-only",
        "build:workflow-retry-parser": "ncc build src/workflow-retry-parser.ts -o dist/workflow-retry-parser --transpile-only",
        "build:workflow-retry": "ncc build src/workflow-retry.ts -o dist/workflow-retry --transpile-only",
        "build:workflow-retry-auto": "ncc build src/workflow-retry-auto.ts -o dist/workflow-retry-auto --transpile-only",
        "build:export-prompt": "ncc build src/export-prompt.ts -o dist/export-prompt --transpile-only",
        "build:clean": "find dist -name '*.d.ts' -o -name '*.d.ts.map' | xargs rm -f",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "lint": "eslint src/",
        "lint:strict": "eslint src/__tests__/lint-failure.ts --rule 'no-console: error' --rule 'no-var: error' --rule 'no-eval: error' --rule '@typescript-eslint/no-unused-vars: error'",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "github-action",
        "merge-conflict",
        "claude",
        "automation"
    ],
    "author": "Chainlink",
    "license": "MIT",
    "engines": {
        "node": ">=20",
        "pnpm": ">=10"
    },
    "dependencies": {
        "@actions/core": "^1.10.1",
        "@actions/exec": "^1.1.1",
        "@actions/github": "^6.0.0",
        "@anthropic-ai/vertex-sdk": "^0.14.4",
        "js-yaml": "^4.1.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.12.10",
        "@vercel/ncc": "^0.38.3",
        "@vitest/coverage-v8": "^2.0.0",
        "eslint": "^9.0.0",
        "typescript": "^5.4.5",
        "typescript-eslint": "^8.0.0",
        "vitest": "^2.0.0"
    }
}